# Posting times (24-hour format)
MORNING_POST_TIME=09:00
EVENING_POST_TIME=18:00

# Railway PostgreSQL URL (added automatically when you add PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# WhatsApp session directory
WHATSAPP_SESSION_DIR=/tmp/whatsapp-session

# Log level
LOG_LEVEL=INFO

# Maximum posts per day
MAX_DAILY_POSTS=5